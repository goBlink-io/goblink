# ===========================================
# Sapphire Environment Configuration
# ===========================================

# 1Click API
ONE_CLICK_JWT=your_jwt_token_from_partners_portal
ONE_CLICK_BASE_URL=https://1click.chaindefuser.com

# Near Intents Explorer API (for transaction tracking)
# Get your JWT token by filling out the API Key Form:
# https://docs.google.com/forms/d/e/1FAIpQLSdrSrqSkKOMb_a8XhwF0f7N5xZ0Y5CYgyzxiAuoC2g4a2N68g/viewform
INTENTS_EXPLORER_JWT=your_jwt_token_from_intents_explorer_api

# Fee Configuration
# Default fee in basis points (used if no tier matches or USD estimate unavailable)
APP_FEE_BPS=35
# Fee recipient NEAR account
APP_FEE_RECIPIENT=goblink.near
# Minimum fee floor in USD
APP_MIN_FEE_USD=0.50
# Tiered pricing (JSON array, sorted by maxAmountUsd ascending)
# Default tiers:
#   < $5,000    → 0.35% (35 bps) — Standard
#   $5K–$50K    → 0.10% (10 bps) — Pro
#   > $50,000   → 0.05% (5 bps)  — Whale
FEE_TIERS=[{"maxAmountUsd":5000,"bps":35},{"maxAmountUsd":50000,"bps":10},{"maxAmountUsd":null,"bps":5}]

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sapphire
REDIS_URL=redis://localhost:6379

# Backend Server
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# NEAR Network Configuration
# Use your custom RPC endpoint with API key here
# Examples:
#   - dRPC: https://lb.drpc.org/ogrpc?network=near&dkey=YOUR_API_KEY
#   - Other providers: include API key in URL or see balances.ts for header config
# Default: https://rpc.fastnear.com (public, rate limited)
NEAR_RPC_URL=https://rpc.fastnear.com
NEXT_PUBLIC_NEAR_NETWORK_ID=mainnet

# Sui Network Configuration
# Blockvision API Key (get from https://docs.blockvision.org)
# Used for gRPC access to Sui network to fetch account coins/balances
BLOCKVISION_API_KEY=your_blockvision_api_key

# EVM RPC Endpoints (Optional - defaults to public RPCs)
# For production, use paid providers like Alchemy, Infura, or QuickNode

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Base (Coinbase L2)
BASE_RPC_URL=https://mainnet.base.org

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com

# Optimism
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# BNB Chain (BSC)
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# Berachain
BERACHAIN_RPC_URL=https://rpc.berachain.com

# Monad
MONAD_RPC_URL=https://rpc.monad.xyz

# Frontend-side Monad RPC (for wagmi)
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# WalletConnect (get project ID from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Sentry (optional)
# SENTRY_DSN=your_sentry_dsn
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# GitHub OAuth Session Secret (used to sign auth JWTs)
SESSION_SECRET=generate-a-random-secret-at-least-32-chars

# Upstash Redis (rate limiting) — optional, rate limiting skipped if not set
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Node Environment
NODE_ENV=development
