# NPM Configuration for Sapphire

# Use legacy peer deps to handle React 18 conflicts with Solana packages
legacy-peer-deps=true

# Skip postinstall scripts (fixes stellar-sdk on Windows, harmless on Linux)
ignore-scripts=true

# Hoist bs58 so transitive deps (@coinbase/cdp-sdk, @reown/appkit-utils) can resolve it
public-hoist-pattern[]=bs58
