{
  "name": "goblink",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev:web": "turbo run dev --filter=@goblink/web",
    "build:web": "turbo run build --filter=@goblink/web"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "next": "^16.1.6",
    "prettier": "^3.4.0",
    "supabase": "^2.76.14",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "minimatch": ">=10.2.1"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
