{
  "name": "goblink",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @goblink/web dev",
    "build": "pnpm --filter @goblink/shared build && pnpm --filter @goblink/connect build && pnpm --filter @goblink/web build",
    "lint": "pnpm --filter @goblink/web lint",
    "clean": "pnpm --filter @goblink/shared clean && pnpm --filter @goblink/connect clean",
    "dev:web": "pnpm --filter @goblink/web dev",
    "build:web": "pnpm --filter @goblink/shared build && pnpm --filter @goblink/connect build && pnpm --filter @goblink/web build"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "next": "^16.1.6",
    "prettier": "^3.4.0",
    "supabase": "^2.76.14",
    
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "minimatch": ">=10.2.3",
      "ajv": ">=6.14.0",
      "bn.js": ">=5.2.3"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
