{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "ONE_CLICK_BASE_URL",
        "ONE_CLICK_JWT",
        "FEATURE_REQUEST_REPO",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "INTENTS_EXPLORER_JWT",
        "APP_FEE_RECIPIENT",
        "BLOCKVISION_API_KEY",
        "NEAR_RPC_URL",
        "APP_FEE_BPS",
        "APP_MIN_FEE_USD",
        "FEE_TIERS"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
