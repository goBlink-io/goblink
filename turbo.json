{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_FEE_BPS",
    "APP_FEE_RECIPIENT",
    "APP_MIN_FEE_USD",
    "BLOCKVISION_API_KEY",
    "FEATURE_REQUEST_REPO",
    "FEE_TIERS",
    "GITHUB_OAUTH_CLIENT_ID",
    "GITHUB_OAUTH_CLIENT_SECRET",
    "INTENTS_EXPLORER_JWT",
    "NEAR_RPC_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID",
    "ONE_CLICK_BASE_URL",
    "ONE_CLICK_JWT",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
